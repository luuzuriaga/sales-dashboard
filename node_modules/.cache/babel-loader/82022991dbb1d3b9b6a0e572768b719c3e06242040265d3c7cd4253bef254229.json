{"ast":null,"code":"import Sidebar from '@/components/Sidebar.vue';\nexport default {\n  name: 'App',\n  components: {\n    Sidebar\n  }\n};","map":{"version":3,"names":["Sidebar","name","components"],"sources":["src/App.vue"],"sourcesContent":["  <div id=\"app\">\n    <Sidebar v-if=\"$route.name !== 'Login'\" />\n    <main class=\"main-content\" :class=\"{ 'main-content--full': $route.name === 'Login' }\">\n      <router-view />\n    </main>\n  </div>\n</template>\n\n<script>\nimport Sidebar from '@/components/Sidebar.vue'\n\nexport default {\n  name: 'App',\n  components: { Sidebar }\n}\n</script>\n\n<style lang=\"scss\">\n@import './styles/variables';\n@import './styles/global';\n\n#app {\n  display: flex;\n  min-height: 100vh;\n  background-color: $bg-page;\n}\n\n.main-content {\n  flex: 1;\n  padding: 2rem;\n  overflow-y: auto;\n  transition: padding 0.3s;\n\n  &--full {\n    padding: 0;\n  }\n\n  @media (max-width: 768px) {\n    padding: 1rem;\n    &--full { padding: 0; }\n  }\n}\n</style>\n"],"mappings":"AASA,OAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAF;EAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}