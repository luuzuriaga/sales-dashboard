{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { mapActions, mapState } from 'vuex';\nexport default {\n  name: 'LoginView',\n  data() {\n    return {\n      email: '',\n      password: ''\n    };\n  },\n  computed: {\n    ...mapState(['loading', 'error'])\n  },\n  methods: {\n    ...mapActions(['login']),\n    async handleSubmit() {\n      try {\n        await this.login({\n          email: this.email,\n          password: this.password\n        });\n        this.$router.push('/dashboard');\n      } catch (err) {\n        // Error manejado en Vuex state\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapActions","mapState","name","data","email","password","computed","methods","handleSubmit","login","$router","push","err"],"sources":["src/views/Login.vue"],"sourcesContent":["<template>\n  <div class=\"login-page\">\n    <div class=\"login-container\">\n      <div class=\"login-card\">\n        <div class=\"brand\">\n          <div class=\"brand__logo\">SD</div>\n          <h1 class=\"brand__name\">SalesDash</h1>\n        </div>\n        <p class=\"subtitle\">Entra para gestionar tus informes comerciales</p>\n\n        <form @submit.prevent=\"handleSubmit\" class=\"login-form\">\n          <div class=\"form-group\">\n            <label for=\"email\">Correo Electrónico</label>\n            <input \n              type=\"email\" \n              id=\"email\" \n              v-model=\"email\" \n              placeholder=\"admin@test.com\"\n              required \n            />\n          </div>\n\n          <div class=\"form-group\">\n            <label for=\"password\">Contraseña</label>\n            <input \n              type=\"password\" \n              id=\"password\" \n              v-model=\"password\" \n              placeholder=\"••••••••\"\n              required \n            />\n          </div>\n\n          <div v-if=\"error\" class=\"login-error\">\n            {{ error }}\n          </div>\n\n          <button type=\"submit\" class=\"btn-login\" :disabled=\"loading\">\n            {{ loading ? 'Iniciando sesión...' : 'Entrar al Dashboard' }}\n          </button>\n        </form>\n\n        <div class=\"login-footer\">\n          ¿No tienes acceso? <a href=\"#\">Contacta con el administrador</a>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { mapActions, mapState } from 'vuex'\n\nexport default {\n  name: 'LoginView',\n  data() {\n    return {\n      email: '',\n      password: ''\n    }\n  },\n  computed: {\n    ...mapState(['loading', 'error'])\n  },\n  methods: {\n    ...mapActions(['login']),\n    async handleSubmit() {\n      try {\n        await this.login({\n          email: this.email,\n          password: this.password\n        })\n        this.$router.push('/dashboard')\n      } catch (err) {\n        // Error manejado en Vuex state\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n@import '../styles/variables';\n\n.login-page {\n  width: 100vw;\n  height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: radial-gradient(circle at top left, lighten($bg-page, 5%), $bg-page);\n  position: relative;\n  overflow: hidden;\n\n  &::before {\n    content: '';\n    position: absolute;\n    width: 300px;\n    height: 300px;\n    background: rgba($primary, 0.1);\n    filter: blur(80px);\n    border-radius: 50%;\n    top: -100px;\n    right: -100px;\n  }\n}\n\n.login-container {\n  width: 100%;\n  max-width: 420px;\n  padding: 2rem;\n  z-index: 10;\n}\n\n.login-card {\n  background: rgba(255, 255, 255, 0.03);\n  backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n  padding: 2.5rem;\n  border-radius: 20px;\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);\n}\n\n.brand {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 2rem;\n\n  &__logo {\n    width: 48px;\n    height: 48px;\n    background: $primary;\n    border-radius: 12px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n    font-weight: 700;\n    color: white;\n  }\n\n  &__name {\n    font-size: 24px;\n    font-weight: 700;\n    color: white;\n    letter-spacing: -0.02em;\n  }\n}\n\n.subtitle {\n  text-align: center;\n  color: $text-secondary;\n  font-size: 14px;\n  margin-bottom: 2rem;\n  line-height: 1.5;\n}\n\n.login-form {\n  display: flex;\n  flex-direction: column;\n  gap: 1.25rem;\n}\n\n.form-group {\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n\n  label {\n    font-size: 13px;\n    font-weight: 500;\n    color: rgba(255, 255, 255, 0.6);\n  }\n\n  input {\n    background: rgba(255, 255, 255, 0.05);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    padding: 12px 16px;\n    border-radius: 8px;\n    color: white;\n    font-family: inherit;\n    transition: all 0.2s;\n\n    &:focus {\n      outline: none;\n      border-color: rgba($primary, 0.5);\n      background: rgba(255, 255, 255, 0.08);\n      box-shadow: 0 0 0 4px rgba($primary, 0.1);\n    }\n  }\n}\n\n.login-error {\n  background: rgba($danger, 0.15);\n  color: lighten($danger, 15%);\n  padding: 10px;\n  border-radius: 6px;\n  font-size: 13px;\n  text-align: center;\n  border: 1px solid rgba($danger, 0.2);\n}\n\n.btn-login {\n  background: $primary;\n  color: white;\n  border: none;\n  padding: 14px;\n  border-radius: 8px;\n  font-weight: 600;\n  font-size: 15px;\n  cursor: pointer;\n  transition: all 0.2s;\n  margin-top: 0.5rem;\n\n  &:hover:not(:disabled) {\n    background: darken($primary, 8%);\n    transform: translateY(-1px);\n    box-shadow: 0 5px 15px rgba($primary, 0.3);\n  }\n\n  &:active:not(:disabled) {\n    transform: translateY(0);\n  }\n\n  &:disabled {\n    opacity: 0.6;\n    cursor: not-allowed;\n  }\n}\n\n.login-footer {\n  margin-top: 2rem;\n  text-align: center;\n  font-size: 13px;\n  color: rgba(255, 255, 255, 0.4);\n\n  a {\n    color: $primary;\n    text-decoration: none;\n    font-weight: 500;\n    &:hover { text-decoration: underline; }\n  }\n}\n</style>\n"],"mappings":";AAmDA,SAAAA,UAAA,EAAAC,QAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,GAAAL,QAAA;EACA;EACAM,OAAA;IACA,GAAAP,UAAA;IACA,MAAAQ,aAAA;MACA;QACA,WAAAC,KAAA;UACAL,KAAA,OAAAA,KAAA;UACAC,QAAA,OAAAA;QACA;QACA,KAAAK,OAAA,CAAAC,IAAA;MACA,SAAAC,GAAA;QACA;MAAA;IAEA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}