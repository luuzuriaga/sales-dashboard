{"ast":null,"code":"import { mapState } from 'vuex';\nexport default {\n  name: 'FilterBar',\n  data() {\n    return {\n      trimestres: ['Q1', 'Q2', 'Q3', 'Q4'],\n      years: ['2025', '2026']\n    };\n  },\n  computed: {\n    ...mapState(['trimestre', 'anio'])\n  }\n};","map":{"version":3,"names":["mapState","name","data","trimestres","years","computed"],"sources":["src/components/FilterBar.vue"],"sourcesContent":["<template>\n  <div class=\"filter-controls\">\n    <!-- Selector de Año -->\n    <div class=\"filter-group\">\n      <button\n        v-for=\"year in years\"\n        :key=\"year\"\n        class=\"filter-btn\"\n        :class=\"{ 'filter-btn--active': anio === year }\"\n        @click=\"$store.dispatch('cambiarAnio', year)\"\n      >\n        {{ year }}\n      </button>\n    </div>\n\n    <div class=\"filter-divider\"></div>\n\n    <!-- Selector de Trimestre -->\n    <div class=\"filter-group\">\n      <button\n        v-for=\"q in trimestres\"\n        :key=\"q\"\n        class=\"filter-btn\"\n        :class=\"{ 'filter-btn--active': trimestre === q }\"\n        @click=\"$store.dispatch('cambiarTrimestre', q)\"\n      >\n        {{ q }}\n      </button>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { mapState } from 'vuex'\n\nexport default {\n  name: 'FilterBar',\n  data() {\n    return {\n      trimestres: ['Q1', 'Q2', 'Q3', 'Q4'],\n      years: ['2025', '2026']\n    }\n  },\n  computed: {\n    ...mapState(['trimestre', 'anio'])\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n@import '../styles/variables';\n\n.filter-bar {\n  display: flex;\n  gap: 6px;\n\n  &__btn {\n    padding: 6px 16px;\n    border-radius: 999px;\n    border: 0.5px solid $border-strong;\n    background: transparent;\n    color: $text-secondary;\n    font-size: 13px;\n    font-family: $font-sans;\n    cursor: pointer;\n    transition: all 0.15s;\n\n    &:hover {\n      background: $bg-muted;\n      color: $text-primary;\n    }\n\n    &--active {\n      background: $text-primary;\n      color: #fff;\n      border-color: transparent;\n    }\n  }\n}\n</style>\n"],"mappings":"AAiCA,SAAAA,QAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,GAAAL,QAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}